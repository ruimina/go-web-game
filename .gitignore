# Track only files required to run this project on a cloud host.
# Everything is ignored by default, then essential files are allowlisted.
*

# Keep this file.
!.gitignore
!README.md
!DEPLOY_ECS_NGINX.md

# Runtime entry + dependency manifest.
!server.js
!package.json
!package-lock.json

# Frontend assets.
!public/
!public/**

# Shared game rules.
!shared/
!shared/**

# Local automation helpers.
!scripts/
!scripts/**
!docs/
!docs/**
